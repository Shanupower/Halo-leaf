# Medusa backend (same host as Store API)
VITE_API_BASE_URL=http://localhost:9000

# Required for Store API (create a publishable key in Medusa Admin → Settings → Publishable API Keys)
VITE_MEDUSA_PUBLISHABLE_KEY=pk_replace_me

# Optional: pin the India region; otherwise the INR / "India" region is selected automatically
# VITE_MEDUSA_REGION_ID=reg_...

# Same origin as VITE_API_BASE_URL unless you serve files from another host
VITE_IMAGE_BASE_URL=http://localhost:9000

# Razorpay (key id / public key for checkout modal — not the secret)
VITE_RAZORPAY_KEY_ID=rzp_test_replace_me

# Optional branding
# VITE_SHOP_NAME=Halo Leaf

# Legacy OTP service for /email flow (optional)
# VITE_OTP_SERVICE_URL=https://your-otp-service.example.com
