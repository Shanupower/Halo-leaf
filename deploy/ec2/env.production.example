# Copy to deploy/ec2/.env on the EC2 host (never commit real secrets).
# Public storefront URL (no trailing slash) — include port 9001
PUBLIC_URL=http://your-server:9001

# Host ports (avoid 80/443 if other projects use them)
BACKEND_PORT=9000
FRONTEND_PORT=9001

# --- Database (docker-compose postgres service) ---
POSTGRES_USER=medusa
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=medusa

# --- Medusa secrets (generate: openssl rand -hex 32) ---
JWT_SECRET=
COOKIE_SECRET=

# CORS — include both ports if you use Admin on :9000 and storefront on :9001
STORE_CORS=http://your-server:9001,http://your-server:9000
ADMIN_CORS=http://your-server:9001,http://your-server:9000
AUTH_CORS=http://your-server:9001,http://your-server:9000

# --- Payments (Razorpay test first, then live together) ---
RAZORPAY_ID=
RAZORPAY_SECRET=
RAZORPAY_ACCOUNT=
RAZORPAY_WEBHOOK_SECRET=

# --- Shiprocket (configure after client adds warehouse + products) ---
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_WEBHOOK_SECRET=
SHIPROCKET_COD=false
DEFAULT_PICKUP_PINCODE=226202

# Optional legacy carrier fallback
RAPIDSHYP_TOKEN=

# Same publishable key as storefront build (create in Medusa Admin after first deploy)
MEDUSA_PUBLISHABLE_KEY=

# --- Frontend build (used by deploy/ec2/deploy.sh) ---
# Storefront talks to nginx on 9001; nginx proxies /store, /auth, etc. to backend
VITE_API_BASE_URL=http://your-server:9001
VITE_IMAGE_BASE_URL=http://your-server:9001
VITE_MEDUSA_PUBLISHABLE_KEY=
VITE_RAZORPAY_KEY_ID=

# Optional
# VITE_MEDUSA_REGION_ID=
# VITE_SHOP_NAME=Halo Leaf
