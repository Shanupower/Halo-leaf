# Copy to .env and adjust. Matches docker-compose.yml in repo root.
# Start DB: from repo root, run: docker compose up -d

DATABASE_URL=postgres://medusa:medusa@localhost:5432/medusa
REDIS_URL=redis://localhost:6379

# Generate strong secrets for production
JWT_SECRET=replace-with-long-random-string
COOKIE_SECRET=replace-with-long-random-string

# Include your Vite dev server and production storefront URLs
STORE_CORS=http://localhost:5173,http://localhost:9000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000

# Create a publishable API key in Medusa Admin (Settings → Publishable API Keys)
# and set the same value in the storefront root `.env` as VITE_MEDUSA_PUBLISHABLE_KEY.

# Payments — RAZORPAY_ACCOUNT is your merchant account id (acc_…), not the key id (rzp_…)
RAZORPAY_ID=
RAZORPAY_SECRET=
RAZORPAY_ACCOUNT=
RAZORPAY_WEBHOOK_SECRET=

# Shiprocket (fulfillment + pincode serviceability — preferred for India)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_WEBHOOK_SECRET=
SHIPROCKET_COD=false
# Optional: same publishable key as storefront VITE_MEDUSA_PUBLISHABLE_KEY
MEDUSA_PUBLISHABLE_KEY=
DEFAULT_PICKUP_PINCODE=226202

# Legacy carrier check (used only if Shiprocket is not configured)
RAPIDSHYP_TOKEN=

# Optional: onboarding / other Medusa vars from .env.template
